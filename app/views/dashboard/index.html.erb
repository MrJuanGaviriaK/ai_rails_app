<div class="min-h-screen bg-[#080e1e] flex flex-col">

  <main class="flex-1 flex items-center justify-center px-8 py-16">
    <div class="w-full max-w-md mx-auto">
      <div class="bg-[#0d1f3e] border border-[#1e3563] rounded-2xl px-10 py-12">
        <p class="text-[#6b8db3] text-sm mb-1"><%= t("dashboard.index.title") %></p>
        <h1 class="text-white text-4xl font-bold mb-2"><%= t("dashboard.index.welcome", name: current_user.name) %></h1>
        <p class="text-[#6b8db3] text-sm"><%= t("dashboard.index.logged_in") %></p>
        <% if current_tenant.present? %>
          <p class="text-[#9fc0e8] text-sm mt-3"><%= t("dashboard.index.current_tenant") %>: <span class="font-semibold text-white"><%= current_tenant.name %></span></p>
        <% end %>
      </div>
    </div>
  </main>

</div>

<%= t("users.mailer.email_changed.document_title") %>
====================================

<%= t("users.mailer.shared.hello", email: @email) %>

<% if @resource.try(:unconfirmed_email?) %>
<%= t("users.mailer.email_changed.requested_change_prefix") %>:
<%= @resource.unconfirmed_email %>

<%= t("users.mailer.email_changed.requested_change_suffix") %>
<% else %>
<%= t("users.mailer.email_changed.changed_prefix") %>:
<%= @resource.email %>

<%= t("users.mailer.email_changed.changed_suffix") %>
<% end %>


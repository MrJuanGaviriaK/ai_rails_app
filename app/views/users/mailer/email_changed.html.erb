<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title><%= t("users.mailer.email_changed.document_title") %></title>
  </head>
  <body style="margin: 0; padding: 0; background-color: #080e1e; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #080e1e;">
      <tr>
        <td align="center" style="padding: 40px 16px;">

          <!-- Card -->
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 560px; background-color: #0d1f3e; border-radius: 8px; overflow: hidden;">

            <!-- Header -->
            <tr>
              <td style="padding: 32px 40px 24px; border-bottom: 1px solid #1a3260;">
                <p style="margin: 0; font-size: 22px; font-weight: 700; color: #ffffff; letter-spacing: -0.3px;">MRJG tools</p>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 32px 40px;">
                <h1 style="margin: 0 0 16px; font-size: 24px; font-weight: 700; color: #ffffff; line-height: 1.3;">
                  <%= @resource.try(:unconfirmed_email?) ? t("users.mailer.email_changed.heading_requested") : t("users.mailer.email_changed.heading_changed") %>
                </h1>
                <p style="margin: 0 0 8px; font-size: 16px; color: #8aaac8; line-height: 1.6;">
                  <%= t("users.mailer.shared.hello", email: @email) %>
                </p>
                <% if @resource.try(:unconfirmed_email?) %>
                  <p style="margin: 0 0 0; font-size: 16px; color: #8aaac8; line-height: 1.6;">
                    <%= t("users.mailer.email_changed.requested_change_prefix") %>
                    <strong style="color: #ffffff;"><%= @resource.unconfirmed_email %></strong>.
                    <%= t("users.mailer.email_changed.requested_change_suffix") %>
                  </p>
                <% else %>
                  <p style="margin: 0 0 0; font-size: 16px; color: #8aaac8; line-height: 1.6;">
                    <%= t("users.mailer.email_changed.changed_prefix") %>
                    <strong style="color: #ffffff;"><%= @resource.email %></strong>.
                    <%= t("users.mailer.email_changed.changed_suffix") %>
                  </p>
                <% end %>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding: 24px 40px; border-top: 1px solid #1a3260;">
                <p style="margin: 0; font-size: 13px; color: #5a7a9a; line-height: 1.6;">
                  <%= t("mailers.shared.footer.email_changed") %><br>
                  <%= t("mailers.shared.footer.unsubscribe") %>
                  <a href="mailto:unsubscribe@mail.mrjg.dev?subject=unsubscribe" style="color: #60a5fa;">unsubscribe@mail.mrjg.dev</a>.
                </p>
              </td>
            </tr>

          </table>
          <!-- /Card -->

        </td>
      </tr>
    </table>
  </body>
</html>

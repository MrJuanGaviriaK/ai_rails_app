<nav class="bg-gray-900 border-b border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <%# Left side: logo + nav links %>
      <div class="flex items-center gap-8">
        <%# Logo %>
        <%= link_to root_path, class: "flex items-center gap-2.5 shrink-0" do %>
          <div class="w-8 h-8 rounded-md bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M4 12c3-5 7-7 12-6" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M4 16c3-2 7-4 12-3" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-white font-semibold text-sm tracking-tight">Ai Rails App</span>
        <% end %>

        <%# Nav links %>
        <div class="hidden sm:flex items-center gap-1">
          <%= link_to t("layouts.navbar.dashboard"), dashboard_path,
                class: "px-3 py-2 rounded-md text-sm font-semibold text-white bg-gray-800" %>
          <% if current_tenant.present? && current_user.seller_workflow_access_for_tenant?(current_tenant) %>
            <%= link_to t("layouts.navbar.sellers"), admin_sellers_path,
                  class: "px-3 py-2 rounded-md text-sm font-semibold text-gray-200 hover:bg-gray-800" %>
          <% end %>
        </div>
      </div>

      <%# Right side: notification bell + user avatar dropdown %>
      <div class="flex items-center gap-4">

        <% if current_user.superadmin? || current_user.admin_for_tenant?(current_tenant) %>
          <div class="relative" data-controller="dropdown">
            <button type="button"
                    data-action="click->dropdown#toggle"
                    class="inline-flex items-center justify-center rounded-lg border border-[#2a3f63] bg-[#0f1f3f] p-2 text-[#b6cae2] transition hover:bg-[#152a52] hover:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
                    aria-label="<%= t("layouts.navbar.open_settings_menu") %>"
                    aria-haspopup="true">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </button>

            <div data-dropdown-target="menu"
                 class="hidden absolute right-0 mt-2 w-72 rounded-lg bg-gray-800 border border-gray-700 shadow-lg ring-1 ring-black/20 z-50 p-2"
                 role="menu"
                 aria-orientation="vertical">
              <div class="px-2 py-2 text-xs font-semibold uppercase tracking-wide text-gray-400">
                <%= t("layouts.navbar.settings") %>
              </div>

              <% if current_user.superadmin? %>
                <%= link_to t("layouts.navbar.tenants"), admin_tenants_path,
                      class: "flex items-center rounded-md px-3 py-2 text-sm text-gray-200 hover:bg-gray-700 hover:text-white transition-colors",
                      role: "menuitem" %>
              <% end %>

              <%= link_to t("layouts.navbar.purchasing_locations"), admin_purchasing_locations_path,
                    class: "flex items-center rounded-md px-3 py-2 text-sm text-gray-200 hover:bg-gray-700 hover:text-white transition-colors",
                    role: "menuitem" %>

              <%= link_to t("layouts.navbar.users"), admin_users_path,
                    class: "flex items-center rounded-md px-3 py-2 text-sm text-gray-200 hover:bg-gray-700 hover:text-white transition-colors",
                    role: "menuitem" %>

              <%= link_to t("layouts.navbar.integrations"), admin_integrations_path,
                    class: "flex items-center rounded-md px-3 py-2 text-sm text-gray-200 hover:bg-gray-700 hover:text-white transition-colors",
                    role: "menuitem" %>

              <%= link_to t("layouts.navbar.e_signature_templates"), admin_e_signature_templates_path,
                    class: "flex items-center rounded-md px-3 py-2 text-sm text-gray-200 hover:bg-gray-700 hover:text-white transition-colors",
                    role: "menuitem" %>

              <% if current_user.superadmin? && switchable_tenants.any? %>
                <div class="my-2 border-t border-gray-700"></div>
                <%= form_with url: admin_switch_tenant_context_path, method: :post, local: true, class: "px-2 pb-1" do %>
                  <label for="tenant_switch" class="mb-1 block text-xs text-gray-400"><%= t("layouts.navbar.switch_tenant") %></label>
                  <%= select_tag :tenant_id,
                        options_from_collection_for_select(switchable_tenants, :id, :name, current_tenant&.id),
                        id: "tenant_switch",
                        class: "ui-select ui-select-sm w-full",
                        onchange: "this.form.requestSubmit()" %>
                <% end %>
              <% elsif current_tenant.present? %>
                <div class="my-2 border-t border-gray-700"></div>
                <p class="px-3 py-2 text-xs text-gray-400">
                  <%= t("layouts.navbar.current_tenant") %>: <span class="font-semibold text-white"><%= current_tenant.name %></span>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="hidden md:flex items-center gap-2 text-xs">
          <span class="text-gray-400"><%= t("layouts.navbar.language") %>:</span>
          <%= link_to "ES", url_for(locale: :es), class: "#{I18n.locale == :es ? "text-white font-semibold" : "text-gray-400 hover:text-white"}" %>
          <span class="text-gray-600">|</span>
          <%= link_to "EN", url_for(locale: :en), class: "#{I18n.locale == :en ? "text-white font-semibold" : "text-gray-400 hover:text-white"}" %>
        </div>

        <%# Bell icon %>
        <button type="button"
                class="relative p-2 rounded-full text-gray-400 hover:text-white hover:bg-gray-800 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500"
                aria-label="<%= t("layouts.navbar.view_notifications") %>">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
          </svg>
        </button>

        <%# Avatar dropdown %>
        <div class="relative" data-controller="dropdown">
          <%# Avatar trigger button %>
          <button type="button"
                  data-action="click->dropdown#toggle"
                  class="flex items-center focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-full"
                  aria-label="<%= t("layouts.navbar.open_user_menu") %>"
                  aria-haspopup="true">
            <span class="sr-only"><%= t("layouts.navbar.open_user_menu") %></span>
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-xs font-semibold select-none">
              <%= current_user.name.first.upcase %>
            </div>
          </button>

          <%# Dropdown menu %>
          <div data-dropdown-target="menu"
               class="hidden absolute right-0 mt-2 w-48 rounded-lg bg-gray-800 border border-gray-700 shadow-lg ring-1 ring-black/20 z-50"
               role="menu"
               aria-orientation="vertical">

            <%# User info header %>
            <div class="px-4 py-3 border-b border-gray-700">
              <p class="text-xs text-gray-400 truncate"><%= t("layouts.navbar.signed_in_as") %></p>
              <p class="text-sm font-medium text-white truncate"><%= current_user.email %></p>
            </div>

            <%# Menu items %>
            <div class="py-1" role="none">
              <%= link_to t("layouts.navbar.your_profile"), "#",
                    class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-700 transition-colors",
                    role: "menuitem" %>

              <%= link_to t("layouts.navbar.settings"), "#",
                    class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-700 transition-colors",
                    role: "menuitem" %>
            </div>

            <div class="py-1 border-t border-gray-700" role="none">
              <%= button_to t("layouts.navbar.sign_out"),
                    destroy_user_session_path,
                    method: :delete,
                    class: "w-full text-left flex items-center gap-2.5 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-700 transition-colors",
                    role: "menuitem",
                    form_class: "w-full" %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</nav>

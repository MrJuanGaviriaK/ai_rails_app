<% total_count = @users.count %>
<% active_count = @users.count(&:archived?).then { |count| total_count - count } %>
<% archived_count = total_count - active_count %>

<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8">
  <div class="mx-auto max-w-7xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.users.index.title") %></h1>
        <p class="mt-1 text-sm text-gray-300"><%= t("admin.users.index.subtitle") %></p>
      </div>

      <%= link_to new_admin_user_path, class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-900/30 transition hover:bg-indigo-500" do %>
        <span class="text-base leading-none">+</span>
        <span><%= t("admin.users.index.new_user") %></span>
      <% end %>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-indigo-900/40 bg-[#102447] p-4">
        <p class="text-xs uppercase tracking-wide text-indigo-300"><%= t("admin.users.index.total_users") %></p>
        <p class="mt-2 text-3xl font-bold text-white"><%= total_count %></p>
      </div>

      <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4">
        <p class="text-xs uppercase tracking-wide text-emerald-300"><%= t("admin.users.index.active") %></p>
        <p class="mt-2 text-3xl font-bold text-emerald-100"><%= active_count %></p>
      </div>

      <div class="rounded-xl border border-slate-500/30 bg-slate-500/10 p-4">
        <p class="text-xs uppercase tracking-wide text-slate-200"><%= t("admin.users.index.archived") %></p>
        <p class="mt-2 text-3xl font-bold text-slate-100"><%= archived_count %></p>
      </div>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-4">
      <%= form_with url: admin_users_path, method: :get, local: true, class: "grid gap-3 sm:grid-cols-[1fr_1fr_1fr_auto]" do |f| %>
        <%= f.select :status,
              options_for_select([
                [t("admin.users.index.filters.active"), "active"],
                [t("admin.users.index.filters.archived"), "archived"],
                [t("admin.users.index.filters.all"), "all"]
              ], @status_filter),
              {},
              class: "ui-select" %>
        <div class="sm:col-span-2"></div>
        <%= f.submit t("admin.users.index.apply"), class: "h-11 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
      <% end %>
    </div>

    <div class="overflow-hidden rounded-xl border border-[#1e3563] bg-[#0d1f3e]">
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="bg-[#0b1a35]">
            <tr>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.users.index.columns.user") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.users.index.columns.roles") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.users.index.columns.tenant") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.users.index.columns.status") %></th>
              <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.users.index.columns.actions") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#1e3563]">
            <% @users.each do |user| %>
              <% user_role_names = user.roles.map(&:name).uniq %>
              <% tenant_names = user.roles.filter_map do |role|
                   next unless role.resource_type == "Tenant"

                   @tenant_name_by_id[role.resource_id]
                 end.uniq %>

              <tr class="transition hover:bg-[#102447]">
                <td class="px-5 py-4 text-sm">
                  <p class="font-semibold text-white"><%= user.name %></p>
                  <p class="text-xs text-gray-400"><%= user.email %></p>
                </td>
                <td class="px-5 py-4 text-sm text-gray-200">
                  <%= user_role_names.map { |role_name| t("admin.users.roles.#{role_name}", default: role_name.humanize) }.join(", ") %>
                </td>
                <td class="px-5 py-4 text-sm text-gray-200">
                  <%= tenant_names.presence&.join(", ") || t("admin.users.index.no_tenant") %>
                </td>
                <td class="px-5 py-4 text-sm">
                  <% status_classes = user.archived? ? "bg-slate-500/10 text-slate-200 border-slate-400/30" : "bg-emerald-500/10 text-emerald-200 border-emerald-400/30" %>
                  <span class="inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium <%= status_classes %>">
                    <%= user.archived? ? t("admin.users.index.archived") : t("admin.users.index.active") %>
                  </span>
                </td>
                <td class="px-5 py-4 text-right text-sm">
                  <% if user.archived? %>
                    <%= button_to t("admin.users.index.restore"),
                          restore_admin_user_path(user),
                          method: :patch,
                          class: "rounded-md border border-emerald-400/35 bg-emerald-500/10 px-3 py-1.5 text-xs font-semibold text-emerald-200 transition hover:bg-emerald-500/20",
                          form_class: "inline",
                          data: { turbo_confirm: t("admin.users.index.restore_confirm") } %>
                  <% else %>
                    <%= button_to t("admin.users.index.archive"),
                          admin_user_path(user),
                          method: :delete,
                          class: "rounded-md border border-red-400/35 bg-red-500/10 px-3 py-1.5 text-xs font-semibold text-red-200 transition hover:bg-red-500/20",
                          form_class: "inline",
                          data: { turbo_confirm: t("admin.users.index.archive_confirm") } %>
                  <% end %>
                </td>
              </tr>
            <% end %>

            <% if @users.empty? %>
              <tr>
                <td colspan="5" class="px-6 py-14 text-center">
                  <p class="text-lg font-semibold text-white"><%= t("admin.users.index.empty_title") %></p>
                  <p class="mt-1 text-sm text-gray-400"><%= t("admin.users.index.empty_description") %></p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

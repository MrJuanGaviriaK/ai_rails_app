<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.mineral_purchases.index.title") %></h1>
      <p class="mt-1 text-sm text-gray-300"><%= t("admin.mineral_purchases.index.subtitle") %></p>
    </div>
    <% if current_user.buyer_for_tenant?(@tenant) %>
      <%= link_to t("admin.mineral_purchases.index.new"), new_admin_mineral_purchase_path, class: "inline-flex h-10 items-center justify-center rounded-md bg-indigo-600 px-4 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-xl border border-[#1e3563] bg-[#0d1f3e]">
    <table class="min-w-full divide-y divide-[#1f3867] text-left text-sm">
      <thead class="bg-[#11274b] text-xs uppercase tracking-wide text-gray-300">
        <tr>
          <th class="px-4 py-3 font-medium"><%= t("admin.mineral_purchases.index.columns.id") %></th>
          <th class="px-4 py-3 font-medium"><%= t("admin.mineral_purchases.index.columns.seller") %></th>
          <th class="px-4 py-3 font-medium"><%= t("admin.mineral_purchases.index.columns.mineral") %></th>
          <th class="px-4 py-3 font-medium"><%= t("admin.mineral_purchases.index.columns.grams") %></th>
          <th class="px-4 py-3 font-medium"><%= t("admin.mineral_purchases.index.columns.total") %></th>
          <th class="px-4 py-3 font-medium"><%= t("admin.mineral_purchases.index.columns.status") %></th>
          <th class="px-4 py-3 font-medium"><%= t("admin.mineral_purchases.index.columns.actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-[#1a335f]">
        <% @mineral_purchases.each do |purchase| %>
          <tr class="hover:bg-[#132a50]">
            <td class="px-4 py-3 text-gray-200">#<%= purchase.id %></td>
            <td class="px-4 py-3 text-gray-200"><%= purchase.seller.full_name %></td>
            <td class="px-4 py-3 text-gray-200"><%= purchase.mineral_type %></td>
            <td class="px-4 py-3 text-gray-200"><%= number_with_precision(purchase.fine_grams, precision: 2) %></td>
            <td class="px-4 py-3 text-gray-200"><%= number_to_currency(purchase.total_price_cop, unit: "$", precision: 2, delimiter: ".", separator: ",") %></td>
            <td class="px-4 py-3 text-gray-200"><%= t("admin.mineral_purchases.statuses.#{purchase.status}") %></td>
            <td class="px-4 py-3">
              <%= link_to t("admin.mineral_purchases.index.show"), admin_mineral_purchase_path(purchase), class: "text-indigo-300 hover:text-indigo-200" %>
            </td>
          </tr>
        <% end %>

        <% if @mineral_purchases.empty? %>
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-gray-300"><%= t("admin.mineral_purchases.index.empty") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

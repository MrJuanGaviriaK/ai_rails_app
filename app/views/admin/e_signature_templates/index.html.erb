<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8">
  <div class="mx-auto max-w-7xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.integrations.index.templates_title") %></h1>
        <p class="mt-1 text-sm text-gray-300"><%= t("admin.e_signature_templates.index.subtitle") %></p>
      </div>

      <%= link_to t("admin.e_signature_templates.index.new_template"), new_admin_e_signature_template_path(integration_id: params[:integration_id]), class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-900/30 transition hover:bg-indigo-500" %>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-4">
      <%= form_with url: admin_e_signature_templates_path, method: :get, local: true, class: "grid gap-3 sm:grid-cols-[1fr_auto]" do |f| %>
        <%= f.select :integration_id,
              options_from_collection_for_select(@integrations, :id, :name, params[:integration_id]),
              { include_blank: t("admin.e_signature_templates.index.all_integrations") },
              class: "ui-select" %>
        <%= f.submit t("admin.e_signature_templates.index.filter"), class: "h-11 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
      <% end %>
    </div>

    <div class="overflow-hidden rounded-xl border border-[#1e3563] bg-[#0d1f3e]">
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="bg-[#0b1a35]">
            <tr>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.e_signature_templates.index.columns.template") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.e_signature_templates.index.columns.integration") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.e_signature_templates.index.columns.pdf") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.e_signature_templates.index.columns.status") %></th>
              <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.e_signature_templates.index.columns.actions") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#1e3563]">
            <% @templates.each do |template| %>
              <tr class="transition hover:bg-[#102447]">
                <td class="px-5 py-4 text-sm text-white">
                  <p class="font-semibold"><%= template.title %></p>
                  <p class="text-xs font-mono text-gray-400"><%= template.provider_template_id %></p>
                </td>
                <td class="px-5 py-4 text-sm text-gray-200"><%= template.integration.name %></td>
                <td class="px-5 py-4 text-sm text-gray-200">
                  <% if template.document.attached? %>
                    <span class="text-emerald-300"><%= t("admin.e_signature_templates.index.pdf_attached") %></span>
                  <% else %>
                    <span class="text-red-300"><%= t("admin.e_signature_templates.index.pdf_missing") %></span>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-sm text-gray-200"><%= template.active? ? t("admin.e_signature_templates.statuses.active") : t("admin.e_signature_templates.statuses.inactive") %></td>
                <td class="px-5 py-4 text-right text-sm">
                  <div class="inline-flex items-center gap-2">
                    <%= link_to t("admin.e_signature_templates.actions.builder"), builder_admin_e_signature_template_path(template), class: "rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-indigo-500" %>
                    <%= link_to t("admin.e_signature_templates.actions.edit"), edit_admin_e_signature_template_path(template), class: "rounded-md border border-[#34588f] bg-[#0a1628] px-3 py-1.5 text-xs font-semibold text-gray-200 transition hover:bg-[#102447]" %>
                    <%= button_to t("admin.e_signature_templates.actions.delete"), admin_e_signature_template_path(template), method: :delete, class: "rounded-md border border-red-400/35 bg-red-500/10 px-3 py-1.5 text-xs font-semibold text-red-200 transition hover:bg-red-500/20", form_class: "inline", data: { turbo_confirm: t("admin.e_signature_templates.actions.delete_confirm") } %>
                  </div>
                </td>
              </tr>
            <% end %>

            <% if @templates.empty? %>
              <tr>
                <td colspan="5" class="px-6 py-14 text-center">
                  <p class="text-lg font-semibold text-white"><%= t("admin.e_signature_templates.index.empty_title") %></p>
                  <p class="mt-1 text-sm text-gray-400"><%= t("admin.e_signature_templates.index.empty_description") %></p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

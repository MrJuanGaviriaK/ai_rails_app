<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8">
  <div class="mx-auto max-w-4xl space-y-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.e_signature_templates.edit.title") %></h1>
        <p class="mt-1 text-sm text-gray-300"><%= t("admin.e_signature_templates.edit.subtitle") %></p>
      </div>

      <%= link_to t("admin.e_signature_templates.actions.builder"), builder_admin_e_signature_template_path(@template), class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-900/30 transition hover:bg-indigo-500" %>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-6">
      <%= render "form", template: @template, integrations: @integrations %>
    </div>
  </div>
</div>

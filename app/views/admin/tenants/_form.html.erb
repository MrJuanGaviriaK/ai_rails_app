<%= form_with model: [:admin, tenant], local: true, class: "space-y-6" do |f| %>
  <% if tenant.errors.any? %>
    <div class="rounded-xl border border-red-500/40 bg-red-950/20 p-4">
      <p class="mb-1 text-sm font-semibold text-red-300"><%= t("admin.tenants.form.fix_errors") %></p>
      <ul class="list-inside list-disc text-sm text-red-200">
        <% tenant.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="rounded-xl border border-[#1e3563] bg-[#0a1628] p-5">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-indigo-300"><%= t("admin.tenants.form.basic_information") %></h2>

    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="space-y-1.5">
        <%= f.label :name, t("admin.tenants.form.name"), class: "block text-sm font-medium text-gray-200" %>
        <%= f.text_field :name, placeholder: t("admin.tenants.form.name_placeholder"), class: "h-11 w-full rounded-lg border border-[#1e3563] bg-[#0f1525] px-3 text-sm text-white placeholder:text-gray-400 focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400" %>
      </div>

      <div class="space-y-1.5">
        <%= f.label :slug, t("admin.tenants.form.slug"), class: "block text-sm font-medium text-gray-200" %>
        <%= f.text_field :slug, placeholder: t("admin.tenants.form.slug_placeholder"), class: "h-11 w-full rounded-lg border border-[#1e3563] bg-[#0f1525] px-3 font-mono text-sm text-white placeholder:text-gray-400 focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400" %>
        <p class="text-xs text-gray-400"><%= t("admin.tenants.form.slug_help") %></p>
      </div>
    </div>
  </section>

  <section class="rounded-xl border border-[#1e3563] bg-[#0a1628] p-5">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-indigo-300"><%= t("admin.tenants.form.lifecycle") %></h2>

    <div class="mt-4 space-y-1.5">
      <%= f.label :status, t("admin.tenants.form.status"), class: "block text-sm font-medium text-gray-200" %>
      <%= f.select :status, options_for_select(Tenant::STATUSES.map { |status| [t("admin.tenants.statuses.#{status}"), status] }, tenant.status), {}, class: "ui-select" %>
      <p class="text-xs text-gray-400"><%= t("admin.tenants.form.status_help") %></p>
    </div>
  </section>

  <section class="rounded-xl border border-[#1e3563] bg-[#0a1628] p-5">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-indigo-300"><%= t("admin.tenants.form.settings") %></h2>

    <div class="mt-4 space-y-1.5">
      <%= label_tag "tenant_settings_json", t("admin.tenants.form.settings_json"), class: "block text-sm font-medium text-gray-200" %>
      <%= text_area_tag "tenant[settings_json]", (tenant.settings.presence || {}).to_json, rows: 8, class: "w-full rounded-lg border border-[#1e3563] bg-[#0f1525] px-3 py-2.5 font-mono text-sm leading-relaxed text-white placeholder:text-gray-400 focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400" %>
      <p class="text-xs text-gray-400"><%= t("admin.tenants.form.settings_example") %></p>
    </div>
  </section>

  <div class="flex flex-col gap-2 border-t border-[#1e3563] pt-4 sm:flex-row sm:items-center">
    <%= f.submit(tenant.persisted? ? t("admin.tenants.form.update_tenant") : t("admin.tenants.form.create_tenant"), class: "inline-flex h-11 items-center justify-center rounded-lg bg-indigo-600 px-5 text-sm font-semibold text-white transition hover:bg-indigo-500") %>
    <%= link_to t("admin.tenants.form.back"), admin_tenants_path, class: "inline-flex h-11 items-center justify-center rounded-lg border border-[#34588f] bg-[#0a1628] px-5 text-sm font-medium text-gray-200 transition hover:bg-[#102447]" %>

    <% if tenant.persisted? %>
      <%= button_to t("admin.tenants.form.archive_tenant"), admin_tenant_path(tenant), method: :delete, class: "inline-flex h-11 items-center justify-center rounded-lg border border-red-400/35 bg-red-500/10 px-5 text-sm font-semibold text-red-200 transition hover:bg-red-500/20", form_class: "sm:ml-auto", data: { turbo_confirm: t("admin.tenants.form.archive_confirm") } %>
    <% end %>
  </div>
<% end %>

<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8">
  <div class="mx-auto max-w-4xl space-y-5">
    <div class="rounded-xl border border-[#1e3563] bg-gradient-to-r from-[#0c1e3c] via-[#163860] to-[#060c18] p-6">
      <p class="text-xs uppercase tracking-wide text-[#8aaac8]"><%= t("admin.tenants.edit.kicker") %></p>
      <h1 class="mt-2 text-3xl font-bold text-white"><%= t("admin.tenants.edit.title") %></h1>
      <p class="mt-2 text-sm text-[#b6cae2]"><%= t("admin.tenants.edit.description_prefix") %> <span class="font-semibold text-white"><%= @tenant.name %></span>.</p>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-5 sm:p-6">
      <%= render "form", tenant: @tenant %>
    </div>
  </div>
</div>

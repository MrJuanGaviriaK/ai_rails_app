<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8">
  <div class="mx-auto max-w-7xl space-y-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.seller_consents.start.title") %></h1>
        <p class="mt-1 text-sm text-gray-300"><%= t("admin.seller_consents.start.subtitle", seller: @seller.full_name) %></p>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <%= link_to t("admin.seller_consents.start.back_to_seller"), admin_seller_path(@seller), class: "rounded-md border border-[#34588f] bg-[#0a1628] px-4 py-2 text-sm font-semibold text-gray-200 transition hover:bg-[#102447]" %>
        <%= button_to t("admin.seller_consents.start.complete_manual"), complete_admin_seller_path(@seller), method: :post, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
      </div>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-4 sm:p-6"
         data-controller="e-signature-signing"
         data-action="resize@window->e-signature-signing#ensureContainerHeight"
         data-e-signature-signing-sign-url-value="<%= @sign_url %>"
         data-e-signature-signing-client-id-value="<%= @client_id %>"
         data-e-signature-signing-complete-url-value="<%= complete_admin_seller_path(@seller) %>"
         data-e-signature-signing-i18n-value="<%= {
           opening: t("admin.seller_consents.start.messages.opening"),
           opened: t("admin.seller_consents.start.messages.opened"),
           finished: t("admin.seller_consents.start.messages.finished"),
           closed: t("admin.seller_consents.start.messages.closed"),
           failed: t("admin.seller_consents.start.messages.failed")
         }.to_json %>">
      <div class="mb-4 flex items-center justify-between gap-3">
        <p class="text-sm text-gray-300" data-e-signature-signing-target="status"><%= t("admin.seller_consents.start.loading") %></p>
        <button type="button"
                class="rounded-md border border-[#34588f] bg-[#081327] px-4 py-2 text-sm font-semibold text-gray-200 transition hover:bg-[#102447]"
                data-action="click->e-signature-signing#open">
          <%= t("admin.seller_consents.start.reopen") %>
        </button>
      </div>

      <div class="h-[calc(100vh-14rem)] min-h-[620px] overflow-hidden rounded-lg border border-[#1e3563] bg-[#081327]"
           data-e-signature-signing-target="container"></div>
    </div>
  </div>
</div>

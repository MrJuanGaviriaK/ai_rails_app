<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8"
     data-controller="integrations-admin"
     data-integrations-admin-tenant-value="<%= @tenant.slug %>"
     data-integrations-admin-i18n-value="<%= {
       actions: {
         templates: t("admin.integrations.js.actions.templates"),
         edit: t("admin.integrations.js.actions.edit"),
         delete: t("admin.integrations.js.actions.delete"),
         activate: t("admin.integrations.js.actions.activate"),
         deactivate: t("admin.integrations.js.actions.deactivate")
       },
       labels: {
         provider_priority: t("admin.integrations.js.labels.provider_priority"),
         status: t("admin.integrations.js.labels.status")
       },
       messages: {
         load_failed: t("admin.integrations.js.messages.load_failed"),
         update_success: t("admin.integrations.js.messages.update_success"),
         update_failed: t("admin.integrations.js.messages.update_failed"),
         network_error: t("admin.integrations.js.messages.network_error"),
         confirm_delete: t("admin.integrations.js.messages.confirm_delete"),
         delete_success: t("admin.integrations.js.messages.delete_success"),
         delete_failed: t("admin.integrations.js.messages.delete_failed"),
         credentials_saved: t("admin.integrations.js.messages.credentials_saved"),
         save_integration_first: t("admin.integrations.js.messages.save_integration_first"),
         testing_connection: t("admin.integrations.js.messages.testing_connection"),
         connection_failed: t("admin.integrations.js.messages.connection_failed"),
         connected_prefix: t("admin.integrations.js.messages.connected_prefix"),
         failed_prefix: t("admin.integrations.js.messages.failed_prefix"),
         saving: t("admin.integrations.js.messages.saving"),
         save_failed: t("admin.integrations.js.messages.save_failed"),
         integration_updated: t("admin.integrations.js.messages.integration_updated"),
         integration_created: t("admin.integrations.js.messages.integration_created")
       },
       modal: {
         add_title: t("admin.integrations.js.modal.add_title"),
         edit_prefix: t("admin.integrations.js.modal.edit_prefix")
       },
       states: {
         active: t("admin.integrations.js.states.active"),
         inactive: t("admin.integrations.js.states.inactive")
       },
       common: {
         unknown_error: t("admin.integrations.js.common.unknown_error"),
         ok: t("admin.integrations.js.common.ok")
       }
     }.to_json %>">
  <div class="mx-auto max-w-7xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.integrations.index.title") %></h1>
        <p class="mt-1 text-sm text-gray-300"><%= t("admin.integrations.index.subtitle") %></p>
      </div>

      <div class="rounded-lg border border-[#1e3563] bg-[#0d1f3e] px-4 py-3 text-right">
        <p class="text-xs uppercase tracking-wide text-gray-400"><%= t("admin.integrations.index.workspace") %></p>
        <p class="text-sm font-mono text-white"><%= @tenant.name %></p>
      </div>
    </div>

    <div data-integrations-admin-target="toast" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-5">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.integrations.index.provider_title") %></h2>
      <button type="button"
              data-action="click->integrations-admin#showAddForm"
              class="group w-full rounded-xl border border-[#34588f] bg-[#102447] p-5 text-left transition hover:bg-[#122c58]">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-base font-semibold text-white">Dropbox Sign</p>
            <p class="mt-1 text-sm text-gray-300"><%= t("admin.integrations.index.provider_description") %></p>
          </div>
          <span class="rounded-lg bg-indigo-600 px-3 py-2 text-xs font-semibold text-white"><%= t("admin.integrations.index.add_button") %></span>
        </div>
      </button>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e]">
      <div class="flex items-center justify-between border-b border-[#1e3563] px-5 py-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-300"><%= t("admin.integrations.index.list_title") %></h2>
        <button type="button"
                data-action="click->integrations-admin#refresh"
                class="rounded-md border border-[#34588f] bg-[#0a1628] px-3 py-1.5 text-xs font-semibold text-gray-200 transition hover:bg-[#102447]">
          <%= t("admin.integrations.index.refresh") %>
        </button>
      </div>
      <div data-integrations-admin-target="list" class="divide-y divide-[#1e3563]"></div>
      <div data-integrations-admin-target="empty" class="hidden px-6 py-12 text-center">
        <p class="text-lg font-semibold text-white"><%= t("admin.integrations.index.empty_title") %></p>
        <p class="mt-1 text-sm text-gray-400"><%= t("admin.integrations.index.empty_description") %></p>
      </div>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-5">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-300"><%= t("admin.integrations.index.templates_title") %></h2>
      <p class="mt-2 text-sm text-gray-300"><%= t("admin.integrations.index.templates_description") %></p>
      <%= link_to t("admin.integrations.index.go_to_templates"), admin_e_signature_templates_path, class: "mt-4 inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
    </div>
  </div>

  <div data-integrations-admin-target="modal" class="hidden fixed inset-0 z-50">
    <div class="absolute inset-0 bg-black/70" data-action="click->integrations-admin#hideModal"></div>
    <div class="relative flex min-h-screen items-center justify-center p-4">
      <div class="w-full max-w-lg rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-6 shadow-2xl">
        <div class="mb-4 flex items-center justify-between">
          <h3 data-integrations-admin-target="modalTitle" class="text-lg font-semibold text-white"><%= t("admin.integrations.js.modal.add_title") %></h3>
          <button type="button" data-action="click->integrations-admin#hideModal" class="text-gray-400 hover:text-white">✕</button>
        </div>

        <input type="hidden" data-integrations-admin-target="editId">

        <div class="space-y-3">
          <div>
            <label class="mb-1 block text-xs text-gray-400"><%= t("admin.integrations.form.name") %></label>
            <input type="text" data-integrations-admin-target="name" class="w-full rounded-lg border border-[#1e3563] bg-[#0a1628] px-3 py-2 text-sm text-white" placeholder="<%= t("admin.integrations.form.name_placeholder") %>">
          </div>
          <div>
            <label class="mb-1 block text-xs text-gray-400"><%= t("admin.integrations.form.api_key") %></label>
            <input type="password" autocomplete="new-password" data-integrations-admin-target="apiKey" class="w-full rounded-lg border border-[#1e3563] bg-[#0a1628] px-3 py-2 text-sm text-white" placeholder="<%= t("admin.integrations.form.api_key_placeholder") %>">
          </div>
          <div>
            <label class="mb-1 block text-xs text-gray-400"><%= t("admin.integrations.form.client_id") %></label>
            <input type="text" data-integrations-admin-target="clientId" class="w-full rounded-lg border border-[#1e3563] bg-[#0a1628] px-3 py-2 text-sm text-white" placeholder="<%= t("admin.integrations.form.client_id_placeholder") %>">
          </div>
          <div>
            <label class="mb-1 block text-xs text-gray-400"><%= t("admin.integrations.form.priority") %></label>
            <input type="number" min="0" data-integrations-admin-target="priority" class="w-full rounded-lg border border-[#1e3563] bg-[#0a1628] px-3 py-2 text-sm text-white" value="0">
          </div>
          <label class="flex items-center gap-2 text-sm text-gray-300">
            <input type="checkbox" data-integrations-admin-target="testMode" class="h-4 w-4 rounded border-[#34588f] bg-[#0a1628]">
            <%= t("admin.integrations.form.test_mode") %>
          </label>
        </div>

        <div class="mt-5 flex items-center gap-2">
          <button type="button" data-action="click->integrations-admin#saveIntegration" data-integrations-admin-target="saveButton" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-500"><%= t("admin.integrations.form.save") %></button>
          <button type="button" data-action="click->integrations-admin#testConnection" data-integrations-admin-target="testButton" class="rounded-md border border-[#34588f] bg-[#0a1628] px-4 py-2 text-sm font-semibold text-gray-200 transition hover:bg-[#102447]"><%= t("admin.integrations.form.test_connection") %></button>
          <span data-integrations-admin-target="saveStatus" class="text-xs text-gray-400"></span>
        </div>
      </div>
    </div>
  </div>
</div>

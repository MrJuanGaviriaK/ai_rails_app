<% total_count = @purchasing_locations.count %>
<% active_count = @purchasing_locations.count(&:active?) %>
<% inactive_count = total_count - active_count %>

<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8">
  <div class="mx-auto max-w-7xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.purchasing_locations.index.title") %></h1>
        <p class="mt-1 text-sm text-gray-300"><%= t("admin.purchasing_locations.index.subtitle") %></p>
      </div>

      <%= link_to new_admin_purchasing_location_path, class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-900/30 transition hover:bg-indigo-500" do %>
        <span class="text-base leading-none">+</span>
        <span><%= t("admin.purchasing_locations.index.new") %></span>
      <% end %>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-xl border border-indigo-900/40 bg-[#102447] p-4">
        <p class="text-xs uppercase tracking-wide text-indigo-300"><%= t("admin.purchasing_locations.index.total") %></p>
        <p class="mt-2 text-3xl font-bold text-white"><%= total_count %></p>
      </div>

      <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4">
        <p class="text-xs uppercase tracking-wide text-emerald-300"><%= t("admin.purchasing_locations.index.active") %></p>
        <p class="mt-2 text-3xl font-bold text-emerald-100"><%= active_count %></p>
      </div>

      <div class="rounded-xl border border-slate-500/30 bg-slate-500/10 p-4">
        <p class="text-xs uppercase tracking-wide text-slate-200"><%= t("admin.purchasing_locations.index.inactive") %></p>
        <p class="mt-2 text-3xl font-bold text-slate-100"><%= inactive_count %></p>
      </div>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-4">
      <%= form_with url: admin_purchasing_locations_path, method: :get, local: true, class: "grid gap-3 lg:grid-cols-[1fr_260px_auto_auto]" do |f| %>
        <%= f.text_field :query, value: params[:query], placeholder: t("admin.purchasing_locations.index.search_placeholder"), class: "h-11 rounded-lg border border-[#1e3563] bg-[#0a1628] px-3 text-sm text-white placeholder:text-gray-400 focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400" %>
        <%= f.select :department, options_for_select([[t("admin.purchasing_locations.index.all_departments"), ""]] + PurchasingLocation::COLOMBIAN_DEPARTMENTS.map { |department| [department, department] }, params[:department]), {}, class: "ui-select" %>
        <%= f.submit t("admin.purchasing_locations.index.apply"), class: "h-11 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
        <%= link_to t("admin.purchasing_locations.index.reset"), admin_purchasing_locations_path, class: "inline-flex h-11 items-center justify-center rounded-lg border border-[#34588f] bg-[#0a1628] px-4 text-sm font-medium text-gray-200 transition hover:bg-[#102447]" %>
      <% end %>
    </div>

    <div class="overflow-hidden rounded-xl border border-[#1e3563] bg-[#0d1f3e]">
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="bg-[#0b1a35]">
            <tr>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.purchasing_locations.index.columns.name") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.purchasing_locations.index.columns.department") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.purchasing_locations.index.columns.city") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.purchasing_locations.index.columns.tenant") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.purchasing_locations.index.columns.status") %></th>
              <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.purchasing_locations.index.columns.actions") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#1e3563]">
            <% @purchasing_locations.each do |purchasing_location| %>
              <tr class="transition hover:bg-[#102447]">
                <td class="px-5 py-4 text-sm">
                  <p class="font-semibold text-white"><%= purchasing_location.name %></p>
                  <p class="text-xs text-gray-400"><%= purchasing_location.address %></p>
                </td>
                <td class="px-5 py-4 text-sm text-gray-200"><%= purchasing_location.department %></td>
                <td class="px-5 py-4 text-sm text-gray-200"><%= purchasing_location.city %></td>
                <td class="px-5 py-4 text-sm text-gray-200"><%= purchasing_location.tenant.name %></td>
                <td class="px-5 py-4 text-sm">
                  <% status_classes = purchasing_location.active? ? "bg-emerald-500/10 text-emerald-200 border-emerald-400/30" : "bg-slate-500/10 text-slate-200 border-slate-400/30" %>
                  <span class="inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium <%= status_classes %>">
                    <%= purchasing_location.active? ? t("admin.purchasing_locations.index.active") : t("admin.purchasing_locations.index.inactive") %>
                  </span>
                </td>
                <td class="px-5 py-4 text-right text-sm">
                  <div class="inline-flex items-center gap-2">
                    <%= link_to t("admin.purchasing_locations.index.show"), admin_purchasing_location_path(purchasing_location), class: "rounded-md border border-[#34588f] bg-[#0a1628] px-3 py-1.5 text-xs font-semibold text-gray-200 transition hover:bg-[#102447]" %>
                    <%= link_to t("admin.purchasing_locations.index.edit"), edit_admin_purchasing_location_path(purchasing_location), class: "rounded-md border border-[#34588f] bg-[#0a1628] px-3 py-1.5 text-xs font-semibold text-gray-200 transition hover:bg-[#102447]" %>
                    <%= button_to t("admin.purchasing_locations.index.archive"), admin_purchasing_location_path(purchasing_location), method: :delete, class: "rounded-md border border-red-400/35 bg-red-500/10 px-3 py-1.5 text-xs font-semibold text-red-200 transition hover:bg-red-500/20", form_class: "inline", data: { turbo_confirm: t("admin.purchasing_locations.index.archive_confirm") } %>
                  </div>
                </td>
              </tr>
            <% end %>

            <% if @purchasing_locations.empty? %>
              <tr>
                <td colspan="6" class="px-6 py-14 text-center">
                  <p class="text-lg font-semibold text-white"><%= t("admin.purchasing_locations.index.empty_title") %></p>
                  <p class="mt-1 text-sm text-gray-400"><%= t("admin.purchasing_locations.index.empty_description") %></p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

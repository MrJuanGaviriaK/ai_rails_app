<div class="min-h-screen bg-[#080e1e] px-4 py-8 sm:px-8">
  <div class="mx-auto max-w-7xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= t("admin.daily_prices.index.title") %></h1>
        <p class="mt-1 text-sm text-gray-300"><%= t("admin.daily_prices.index.subtitle") %></p>
      </div>

      <%= link_to t("admin.daily_prices.index.new"), new_admin_daily_price_path, class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-900/30 transition hover:bg-indigo-500" %>
    </div>

    <div class="rounded-xl border border-[#1e3563] bg-[#0d1f3e] p-4">
      <%= form_with url: admin_daily_prices_path, method: :get, local: true, class: "grid gap-3 lg:grid-cols-[1fr_180px_200px_auto_auto]" do |f| %>
        <%= f.text_field :mineral_type, value: @mineral_filter, placeholder: t("admin.daily_prices.index.filters.mineral_placeholder"), class: "h-11 rounded-lg border border-[#1e3563] bg-[#0a1628] px-3 text-sm text-white placeholder:text-gray-400 focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400" %>
        <%= f.select :state,
              options_for_select([[t("admin.daily_prices.index.filters.all_states"), ""]] + DailyPrice::STATES.map { |state| [t("admin.daily_prices.states.#{state}"), state] }, @state_filter),
              {},
              class: "ui-select" %>
        <%= f.date_field :price_date, value: @price_date_filter, class: "h-11 rounded-lg border border-[#1e3563] bg-[#0a1628] px-3 text-sm text-white focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400" %>
        <%= f.submit t("admin.daily_prices.index.apply"), class: "h-11 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
        <%= link_to t("admin.daily_prices.index.reset"), admin_daily_prices_path, class: "inline-flex h-11 items-center justify-center rounded-lg border border-[#34588f] bg-[#0a1628] px-4 text-sm font-medium text-gray-200 transition hover:bg-[#102447]" %>
      <% end %>
    </div>

    <div class="overflow-hidden rounded-xl border border-[#1e3563] bg-[#0d1f3e]">
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="bg-[#0b1a35]">
            <tr>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.daily_prices.index.columns.price_date") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.daily_prices.index.columns.mineral_type") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.daily_prices.index.columns.unit_price_cop") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.daily_prices.index.columns.state") %></th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.daily_prices.index.columns.review") %></th>
              <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-400"><%= t("admin.daily_prices.index.columns.actions") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#1e3563]">
            <% @daily_prices.each do |daily_price| %>
              <tr class="transition hover:bg-[#102447]">
                <td class="px-5 py-4 text-sm text-gray-200"><%= l(daily_price.price_date) %></td>
                <td class="px-5 py-4 text-sm text-white"><%= daily_price.mineral_type %></td>
                <td class="px-5 py-4 text-sm text-gray-200"><%= number_to_currency(daily_price.unit_price_cop, unit: "$", precision: 2) %></td>
                <td class="px-5 py-4 text-sm">
                  <% state_classes = case daily_price.state
                     when "approved" then "bg-emerald-500/10 text-emerald-200 border-emerald-400/30"
                     when "rejected" then "bg-red-500/10 text-red-200 border-red-400/30"
                     else "bg-slate-500/10 text-slate-200 border-slate-400/30"
                     end %>
                  <span class="inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium <%= state_classes %>">
                    <%= t("admin.daily_prices.states.#{daily_price.state}") %>
                  </span>
                </td>
                <td class="px-5 py-4 text-sm text-gray-300">
                  <p><%= daily_price.reviewed_by&.name || "-" %></p>
                  <% review_timestamp = daily_price.approved_at || daily_price.rejected_at %>
                  <p class="text-xs text-gray-400"><%= review_timestamp ? l(review_timestamp, format: :short) : "-" %></p>
                </td>
                <td class="px-5 py-4 text-right text-sm">
                  <%= link_to t("admin.daily_prices.index.edit"), edit_admin_daily_price_path(daily_price), class: "rounded-md border border-[#34588f] bg-[#0a1628] px-3 py-1.5 text-xs font-semibold text-gray-200 transition hover:bg-[#102447]" %>
                </td>
              </tr>
            <% end %>

            <% if @daily_prices.empty? %>
              <tr>
                <td colspan="6" class="px-6 py-14 text-center">
                  <p class="text-lg font-semibold text-white"><%= t("admin.daily_prices.index.empty_title") %></p>
                  <p class="mt-1 text-sm text-gray-400"><%= t("admin.daily_prices.index.empty_description") %></p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
